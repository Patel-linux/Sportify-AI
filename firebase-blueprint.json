{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "favorites": { "type": "array", "items": { "type": "string" }, "description": "List of favorite product IDs." },
        "preferences": { "type": "array", "items": { "type": "string" }, "description": "User's sports preferences." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a sports equipment item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "price", "category"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in the user's shopping cart.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "price", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "productId", "price", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog data."
    },
    "/users/{userId}/cart/{itemId}": {
      "schema": "CartItem",
      "description": "User's shopping cart items."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global order history."
    }
  }
}
